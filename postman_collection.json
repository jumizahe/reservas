{
  "info": {
    "name": "Sistema de Reservas de Citas Médicas",
    "description": "Colección de endpoints para probar el API del sistema de reservas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Pacientes",
      "item": [
        {
          "name": "Crear paciente",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/patients",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentNumber\": \"1234567890\",\n  \"fullName\": \"Juan Pérez\",\n  \"email\": \"juan.perez@email.com\",\n  \"phone\": \"+573001234567\"\n}"
            }
          }
        },
        {
          "name": "Obtener paciente por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/patients/1"
          }
        },
        {
          "name": "Listar pacientes (paginado)",
          "request": {
            "method": "GET",
            "url": {
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            },
            "raw": "{{baseUrl}}/api/patients"
          }
        },
        {
          "name": "Actualizar paciente",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/patients/1",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Juan Pérez Updated\",\n  \"email\": \"juan.updated@email.com\",\n  \"phone\": \"+573009999999\"\n}"
            }
          }
        }
      ]
