    {
      "name": "6. Citas",
      "item": [
        {
          "name": "Crear cita",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/appointments",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"doctorId\": 1,\n  \"officeId\": 1,\n  \"appointmentTypeId\": 1,\n  \"startAt\": \"2026-04-15T09:00:00\"\n}"
            }
          }
        },
        {
          "name": "Obtener cita por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/appointments/1"
          }
        },
        {
          "name": "Listar citas (paginado)",
          "request": {
            "method": "GET",
            "url": {
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ],
              "raw": "{{baseUrl}}/api/appointments"
            }
          }
        },
        {
          "name": "Confirmar cita",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/appointments/1/confirm"
          }
        },
        {
          "name": "Cancelar cita",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/appointments/1/cancel",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cancellationReason\": \"Paciente pidió cambio de horario\"\n}"
            }
          }
        },
        {
          "name": "Completar cita",
          "request": {
            "method": "PUT",
            "url": {
              "query": [
                {"key": "observations", "value": "Paciente presentó síntomas de alergia"}
              ],
              "raw": "{{baseUrl}}/api/appointments/1/complete"
            }
          }
        },
        {
          "name": "Marcar como no presentados",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/appointments/1/no-show"
          }
        }
      ]
